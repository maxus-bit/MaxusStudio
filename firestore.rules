rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Коллекция пользователей
    match /users/{userId} {
      allow read: if isOwner(userId);
      // Пользователь не может создавать запись с кредитами вручную.
      // Это делает Cloud Function onUserCreated.
      // Если клиент попытается создать запись, это будет отклонено,
      // если он попытается задать кредиты > 0 или другие защищенные поля,
      // которые должны задаваться только сервером.
      // Но лучше всего запретить клиенту создавать user document вообще,
      // полагаясь на триггер.
      allow create: if false; 

      // При обновлении запрещаем менять кредиты и подписку
      allow update: if isOwner(userId) 
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['credits', 'subscriptionStatus', 'subscriptionPlan']));
      
      match /chats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Коллекция Stripe Customers (создается расширением)
    // Разрешаем пользователю читать свои платежные данные
    match /customers/{uid} {
      allow read: if isOwner(uid);

      match /checkout_sessions/{id} {
        allow read, write: if isOwner(uid);
      }
      match /subscriptions/{id} {
        allow read: if isOwner(uid);
      }
      match /payments/{id} {
        allow read: if isOwner(uid);
      }
    }

    // Коллекция Продуктов (только чтение для всех)
    match /products/{id} {
      allow read: if true;

      match /prices/{id} {
        allow read: if true;
      }
      match /tax_rates/{id} {
        allow read: if true;
      }
    }
  }
}
